# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
# Server-only Mapbox token (URL-restriction off, used for Search Box API proxy).
# Generate a separate secret token from the Mapbox account dashboard.
MAPBOX_SERVER_TOKEN=

# Google Places API (server-only)
GOOGLE_PLACES_API_KEY=

# API Key Encryption (required)
ENCRYPTION_SECRET=

# DataForSEO API
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Gemini API (server-only) — powers AI features (Phase 1+).
# Get a key from https://aistudio.google.com/apikey
# When this is unset, AI routes return 503 and the Settings AI toggle is disabled.
GOOGLE_GENERATIVE_AI_API_KEY=

# Langfuse (server-only) — LLM observability (traces for every Gemini call).
# Keys: cloud.langfuse.com → Settings → API Keys. EU data region.
# When unset, the Langfuse span processor is skipped entirely (no-op).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
